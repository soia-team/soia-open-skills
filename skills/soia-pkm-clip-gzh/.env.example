# soia-pkm-clip-gzh — 凭据模板
#
# 不要把真实值填进这个文件再 git add！更安全的做法是复制到下面任一私有位置，
# 脚本会自动探测加载（无需手动 source）：
#   $SOIA_PKM_ENV_FILE
#   ~/.config/soia-pkm/env
#   ~/.soia-pkm.env
# 用法：cp .env.example ~/.config/soia-pkm/env  然后编辑真实值。

# ── 路 A · 官方 API（scripts/fetch_api.py）──────────────────────
# 来源：mp.weixin.qq.com 登录后台 →「设置与开发」→「开发」→「基本配置」。
# 前提：公众号需已认证（服务号/订阅号），且把调用方公网 IP 加进同一页的
# 「IP白名单」（本机公网 IP 可用 `curl ifconfig.me` 查）。
# 2025-07 起个人主体账号/未认证账号的发布类接口权限已被回收，多数个人号
# 这条路线大概率跑不通，见 SKILL.md「路 A 接口依据与限制」。
WECHAT_APP_ID=<YOUR_APP_ID>
WECHAT_APP_SECRET=<YOUR_APP_SECRET>

# ── 路 B · 登录态 Cookie（scripts/fetch_cookie.py）──────────────
# 来源：登录 mp.weixin.qq.com 后，打开该公众号任意历史文章或
# profile_ext?action=home，在浏览器开发者工具「网络」面板里抓包获取。
# key / pass_ticket / appmsg_token 几小时到几天会过期，过期需重新抓包替换。
# 仅用于归档你自己管理的公众号——见 SKILL.md「路 B 接口依据与限制」的
# 合规提醒。
WECHAT_BIZ=<__biz，从该公众号任意文章链接的 __biz 参数取>
WECHAT_KEY=<key，抓包取，会过期>
WECHAT_PASS_TICKET=<pass_ticket，抓包取，会过期>
WECHAT_APPMSG_TOKEN=<appmsg_token，抓包取，会过期>
WECHAT_COOKIE=<完整 Cookie 请求头字符串，抓包取，会过期>
# 抓包样本里通常固定为 777，一般不用改
WECHAT_UIN=777

# ── 路 C · 公众号后台接口（scripts/fetch_mp.py）─────────────────
# 来源：登录 mp.weixin.qq.com 后台，随便打开一篇文章编辑/列表页，F12 打开
# 「网络」面板，从任意 mp.weixin.qq.com 请求的 URL 里复制 token 参数、从
# 请求头复制完整 Cookie 字符串。token/cookie 几小时会过期，过期需重新抓包。
# 仅用于归档你自己管理的公众号——见 SKILL.md「路 C 接口依据与限制」的
# 合规提醒。
WECHAT_MP_TOKEN=<token，抓包取，几小时会过期>
WECHAT_MP_COOKIE=<完整 Cookie 请求头字符串，抓包取，几小时会过期>
# 可选：已知 fakeid 时直接填，跳过 --name 走 searchbiz 搜索这一步
WECHAT_MP_FAKEID=<可选，公众号的 fakeid>

# ── 两条路共用（可选）────────────────────────────────────────
# API 不返回公众号昵称，两个脚本都不填 --account-name 时用这个兜底
WECHAT_ACCOUNT_NAME=<公众号显示名，可选>
# vault 路径 / 落地子目录：也可用 --vault / --out 传，二选一即可
OBSIDIAN_VAULT=<你的 vault 绝对路径>
OBSIDIAN_GZH_OUT=<vault 内相对目录，例如 Inbox/gzh-articles>
